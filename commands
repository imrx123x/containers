docker build -t docker_test_app .
docker run --rm -p 5000:5000 docker_test_app                                    # -p port_on_my_comp:port_in_container
docker run --rm -p 5001:5000 -v $(pwd):/app docker_test_app                     # without rerunning docker build
docker compose up/down                                                          # use docker-compose.yml, reloads work
docker compose up -d                                                            # same but in the background
docker compose logs -f                                                          # logs
docker compose up --build                                                       # new build, use docker-compose.yml
docker compose down -v                                                          # -v deletes old psql data

# processes
lsof -i :5000

# tests
docker-compose run --rm app pytest                                              # run container with tests
docker-compose run --rm -w /app -e PYTHONPATH=/app app pytest                   # if /app not found i container